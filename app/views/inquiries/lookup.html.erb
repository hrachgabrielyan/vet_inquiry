<div>
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-slate-900">Find Your Inquiries</h1>
    <p class="text-slate-500 mt-2">Enter the email address you used when submitting your inquiry.</p>
  </div>

  <%= form_with url: lookup_inquiries_path, method: :get, local: true do |f| %>
    <div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 flex gap-3">
      <%= f.email_field :email, value: params[:email], placeholder: "your@email.com",
            class: "flex-1 border border-slate-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      <%= f.submit "Search",
            class: "bg-blue-800 hover:bg-blue-700 text-white px-6 py-2.5 rounded-lg font-medium transition-colors cursor-pointer" %>
    </div>
  <% end %>

  <% if @inquiries %>
    <div class="mt-8">
      <% if @inquiries.empty? %>
        <div class="bg-white rounded-2xl border border-slate-100 p-10 text-center text-slate-400">
          No inquiries found for <span class="font-medium text-slate-600"><%= params[:email] %></span>.
        </div>
      <% else %>
        <p class="text-sm text-slate-500 mb-4"><%= @inquiries.count %> <%= "inquiry".pluralize(@inquiries.count) %> found</p>
        <div class="space-y-3">
          <% @inquiries.each do |inquiry| %>
            <%= link_to inquiry_path(inquiry.reference_number), class: "block" do %>
              <%= render "status_card", inquiry: inquiry %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
