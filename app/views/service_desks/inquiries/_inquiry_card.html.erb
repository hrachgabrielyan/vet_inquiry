<% status_styles = {
  "submitted"      => "bg-amber-50 text-amber-700 border-amber-200",
  "routed"         => "bg-blue-50 text-blue-700 border-blue-200",
  "in_progress"    => "bg-purple-50 text-purple-700 border-purple-200",
  "resolved"       => "bg-emerald-50 text-emerald-700 border-emerald-200",
  "routing_failed" => "bg-red-50 text-red-700 border-red-200"
} %>

<div class="bg-white rounded-2xl shadow-sm border border-slate-100 p-6 flex items-start justify-between gap-6 hover:shadow-md transition-shadow">
  <div class="flex-1 space-y-2">
    <div class="flex items-center gap-3">
      <span class="font-mono font-bold text-blue-900 text-sm"><%= inquiry.reference_number %></span>
      <span class="px-2.5 py-0.5 rounded-full text-xs font-semibold border <%= status_styles[inquiry.status] %>">
        <%= inquiry.status.humanize %>
      </span>
    </div>
    <p class="font-medium text-slate-800"><%= inquiry.first_name %> <%= inquiry.last_name %></p>
    <p class="text-sm text-slate-500"><%= inquiry.category.humanize %> &mdash; <%= inquiry.topic %></p>
    <% if inquiry.service_desk %>
      <p class="text-xs text-slate-400">Desk: <%= inquiry.service_desk.name %></p>
    <% end %>
  </div>

  <div class="flex-shrink-0">
    <%= form_with url: update_status_service_desks_inquiry_path(inquiry), method: :patch do |f| %>
      <%= f.select :status,
            Inquiry.statuses.keys.map { |s| [s.humanize, s] },
            { selected: inquiry.status },
            class: "border border-slate-200 rounded-lg px-3 py-2 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 cursor-pointer",
            onchange: "this.form.requestSubmit()" %>
    <% end %>
  </div>
</div>
